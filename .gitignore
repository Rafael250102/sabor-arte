# ==================== DEPENDÊNCIAS ====================
node_modules/
.pnp
.pnp.js

# ==================== VARIÁVEIS DE AMBIENTE ====================
# Nunca versionar arquivos .env — contêm senhas e chaves secretas
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==================== BUILD / DIST ====================
dist/
build/
.vite/

# ==================== IMAGENS DOS PRATOS (geradas em runtime) ====================
# Imagens são geradas pelo Multer e não devem ser versionadas
backend/public/imgs/plates/*
# Mantém a estrutura de pastas no repositório
!backend/public/imgs/plates/.gitkeep

# ==================== LOGS ====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==================== SISTEMA OPERACIONAL ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==================== EDITORES / IDEs ====================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==================== COBERTURA DE TESTES ====================
coverage/
.nyc_output/

